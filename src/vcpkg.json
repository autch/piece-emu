{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "piece-emu",
  "version": "0.1.0",
  "dependencies": [
    "gtest",
    "cli11"
  ],
  "features": {
    "system": {
      "description": "Full-system frontend with display and audio (requires SDL3 and Dear ImGui)",
      "dependencies": [
        "sdl3",
        {
          "name": "imgui",
          "features": ["sdl3-binding", "sdl3-renderer-binding"]
        }
      ]
    }
  }
}
